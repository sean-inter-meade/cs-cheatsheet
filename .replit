run = "uv sync && .venv/bin/uvicorn backend.app:app --host 0.0.0.0 --port 8080"
entrypoint = "backend/app.py"
modules = ["python-3.11"]
disableGuessImports = true

[nix]
channel = "stable-24_05"
packages = ["libxcrypt", "libyaml", "gcc", "uv"]

[env]
PYTHONPATH = "/home/runner/${REPL_SLUG}"
PIP_USER = "0"

[deployment]
run = ["sh", "-c", ".venv/bin/uvicorn backend.app:app --host 0.0.0.0 --port 8080"]
deploymentTarget = "cloudrun"
# Force uv to synchronize directly using your pyproject.toml and uv.lock files safely
build = ["sh", "-c", "uv sync --frozen"]

[[ports]]
localPort = 8080
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ".venv/bin/uvicorn backend.app:app --host 0.0.0.0 --port 8080"
waitForPort = 8080

[agent]
expertMode = true