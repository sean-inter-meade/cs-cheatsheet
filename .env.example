# Intercom API
INTERCOM_API_TOKEN=your_intercom_api_token_here
INTERCOM_API_BASE=https://api.intercom.io

# OpenAI (for AI-powered problem analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Cache
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=100

# Rate limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# Custom Data Attribute key names (match exact Intercom attribute names)
CDA_SEGMENT_KEY=Support team customer segment
CDA_REGION_KEY=Support team customer region
CDA_SETTINGS_ACCESS_KEY=Can access workspace settings
CDA_IMPERSONATION_KEY=Has impersonation consent
CDA_COMPANY_CREATED_AT_KEY=Company created at
